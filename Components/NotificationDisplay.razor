@inject NotificationService NotifyService
@rendermode InteractiveServer

<div class="premium-dark-card">
    <div class="card-header-block">
        <h2 class="terminal-title">Live Notification Center</h2>
        <p class="terminal-subtitle">Current Display Mode: @NotifyService.GetCurrentStyle()</p>
    </div>

    <div class="action-grid" style="margin-bottom: 20px;">
        <button class="action-btn-main btn-glow-purple" @onclick="LoadNotifications">
            Fetch Latest Notifications
        </button>
    </div>

    <div class="profile-stream-section">
        @if (notifications == null)
        {
            <p class="profile-meta-warn">No notifications loaded yet. Click the fetch button.</p>
        }
        else if (notifications.Count == 0)
        {
            <p class="profile-meta-warn">Notification queue is empty.</p>
        }
        else
        {
            <div class="form-container" style="width: 100%;">
                @foreach (var note in notifications)
                {
                    @if (NotifyService.GetCurrentStyle() == "Compact")
                    {
                        <div class="display-metric-box" style="padding: 10px; margin-bottom: 10px; background: #1a1333;">
                            <span class="status-badge status-online" style="font-size: 1rem; text-align: left;">
                                ⚠️ @note.Split(':')[0]
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="warning-alert-box" style="margin-bottom: 12px; border: 1px solid rgba(217, 70, 239, 0.3);">
                            <strong style="color: #d946ef; display: block; margin-bottom: 4px;">SYSTEM LOG</strong>
                            <p>@note</p>
                            <span style="font-size: 0.75rem; color: #a855f7; display: block; margin-top: 6px;">Timestamp: Live Sync Active</span>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    private List<string>? notifications;

    private async Task LoadNotifications()
    {
        notifications = await NotifyService.GetNotificationsAsync();
    }
}
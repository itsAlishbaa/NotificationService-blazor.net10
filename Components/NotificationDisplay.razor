@using Q6
@inject NotificationService NotifyService
@implements IDisposable
@rendermode InteractiveServer

<div class="premium-dark-card">
    <div class="card-header-block">
        <h2 class="terminal-title">Live Notification Center</h2>
        <div class="display-metric-box" style="margin-top: 15px; padding: 10px;">
            <span class="metric-label">Display Mode</span>
            <span class="status-badge status-online">@NotifyService.GetCurrentStyle()</span>
        </div>
    </div>

    <div class="action-grid">
        <button class="action-btn-main btn-glow-purple" @onclick="LoadNotifications">
            Fetch Latest Notifications
        </button>
    </div>

    <div class="profile-stream-section" style="margin-top: 24px;">
        @if (notifications == null)
        {
            <p class="profile-meta-warn">No notifications loaded yet. Click the fetch button.</p>
        }
        else if (notifications.Count == 0)
        {
            <p class="profile-meta-warn">Notification queue is empty.</p>
        }
        else
        {
            <div class="form-container">
                @foreach (var note in notifications)
                {
                    @if (NotifyService.GetCurrentStyle() == "Compact")
                    {
                        <div class="display-metric-box" style="padding: 12px; margin-bottom: 8px; border-color: rgba(16, 185, 129, 0.3);">
                            <span style="color: #10b981; font-weight: 700; font-size: 0.9rem; display: block; text-align: left;">
                                ⚠️ @note.Split(':')[0]
                            </span>
                        </div>
                    }
                    else
                    {
                        <div class="warning-alert-box">
                            <strong style="color: #d946ef; display: block; font-size: 0.85rem; margin-bottom: 4px;">SYSTEM LOG</strong>
                            <p style="margin: 0; color: #e2e8f0; font-size: 0.9rem; line-height: 1.4;">@note</p>
                            <span style="font-size: 0.7rem; color: #a855f7; display: block; margin-top: 6px;">Timestamp: Live Sync Active</span>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>

@code {
    private List<string>? notifications;

    protected override void OnInitialized()
    {
        // Subscribe to service state changes
        NotifyService.OnStateChanged += RefreshUI;
    }

    private async Task LoadNotifications()
    {
        notifications = await NotifyService.GetNotificationsAsync();
    }

    private void RefreshUI()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe to protect memory leaks
        NotifyService.OnStateChanged -= RefreshUI;
    }
}
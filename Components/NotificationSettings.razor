@using Q6
@inject NotificationService NotifyService
@rendermode InteractiveServer

<div class="premium-dark-card">
    <div class="card-header-block">
        <h2 class="terminal-title">Notification Settings</h2>
        <p class="terminal-subtitle">Modify service configuration dynamically</p>
    </div>

    <div class="form-container">
        <div class="input-group-block">
            <label>Default Number of Notifications</label>
            <input type="number" class="custom-terminal-input"
                   value="@NotifyService.GetCurrentCount()"
                   @onchange="@(e => NotifyService.UpdateCount(int.Parse(e.Value?.ToString() ?? "3")))"
                   min="1" max="10" />
        </div>

        <div class="input-group-block">
            <label>Notification Style</label>
            <select class="custom-terminal-input"
                    value="@NotifyService.GetCurrentStyle()"
                    @onchange="@(e => NotifyService.UpdateStyle(e.Value?.ToString() ?? "Detailed"))">
                <option value="Compact">Compact View</option>
                <option value="Detailed">Detailed View</option>
            </select>
        </div>
    </div>
</div>